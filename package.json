{
  "name": "pixel-guess",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:party\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0 --config client/vite.config.ts",
    "dev:party": "partykit dev",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "tsc -p tsconfig.json && vite build --config client/vite.config.ts",
    "deploy:party": "partykit deploy",
    "start": "tsx server/src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "partykit": "^0.0.115",
    "partysocket": "^1.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.12"
  }
}
